{
  "version": 1,
  "hooks": {
    "afterFileEdit": [
      {
        "command": "bun run fix"
      },
      {
        "command": "bash .cursor/hooks/validate-edit.sh"
      }
    ],
    "beforeShellExecution": [
      {
        "command": "bash .cursor/hooks/validate-shell.sh"
      }
    ]
  }
}

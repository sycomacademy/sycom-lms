{
  "editor.defaultFormatter": "biomejs.biome",
  "typescript.tsdk": "node_modules/typescript/lib",
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,
  "emmet.showExpandedAbbreviation": "never",
  "files.exclude": {
    "**/.DS_Store": true,
    "**/.agents": false,
    "**/.claude": false,
    "**/.cursor": false,
    "**/.git": true,
    "**/.gitignore": false,
    "**/.hg": true,
    "**/.idea": false,
    "**/.next": false,
    "**/.opencode": false,
    "**/.svn": true,
    "**/.vscode": false,
    "**/node_modules": false,
    "**/Thumbs.db": true,
    "**/biome.json": false,
    "**/bun.lock": false,
    "**/CHANGELOG.md": false,
    "**/components.json": false,
    "**/lefthook.yml": false,
    "**/next-env.d.ts": false,
    "**/next.config.ts": false,
    "**/postcss.config.mjs": false,
    "**/README.md": false,
    "**/tsconfig.json": false
  },
  "files.associations": {
    "*.css": "tailwindcss"
  },
  "[javascript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[json]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[html]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[css]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[yaml]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[markdown]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[mdx]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "editor.codeActionsOnSave": {
    "source.fixAll.biome": "always",
    "source.organizeImports.biome": "always"
  }
}

{
  "name": "sycom-lsm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:all": "bunx concurrently --kill-others --names \"next,trigger\" --prefix-colors \"yellow,blue\" \"next dev\" \"bunx trigger dev\"",
    "build": "next build",
    "start": "next start",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "typecheck": "tsc --noEmit",
    "prep": "lefthook install",
    "email:dev": "email dev --port 3001 --dir=packages/email/templates",
    "db:generate": "bun x drizzle-kit generate --config=packages/db/drizzle.config.ts",
    "db:migrate": "bun x drizzle-kit migrate --config=packages/db/drizzle.config.ts",
    "db:push": "bun x drizzle-kit push --config=packages/db/drizzle.config.ts",
    "db:studio": "bun x drizzle-kit studio --config=packages/db/drizzle.config.ts",
    "db:seed": "bun run packages/db/seed.ts",
    "db:neon-switch": "bash scripts/switch-db-branch.sh",
    "db:neon-merge": "bash scripts/neon-merge-branch.sh",
    "trigger:dev": "trigger dev",
    "trigger:deploy": "trigger deploy"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@better-auth/infra": "^0.1.8",
    "@better-auth/passkey": "^1.5.2",
    "@better-auth/scim": "^1.5.2",
    "@better-auth/sso": "^1.5.2",
    "@hookform/resolvers": "^5.2.2",
    "@neondatabase/serverless": "^1.0.2",
    "@react-email/components": "1.0.7",
    "@react-email/render": "^2.0.4",
    "@t3-oss/env-nextjs": "^0.13.10",
    "@tanstack/react-form": "^1.28.0",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-table": "^8.21.3",
    "@trigger.dev/sdk": "4.4.2",
    "@trpc/client": "^11.9.0",
    "@trpc/server": "^11.9.0",
    "@trpc/tanstack-react-query": "^11.9.0",
    "better-auth": "^1.5.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.564.0",
    "motion": "^12.34.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "pino": "^10.3.1",
    "posthog-js": "^1.358.0",
    "posthog-node": "^5.25.0",
    "react": "19.2.4",
    "react-day-picker": "^9.13.2",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.71.1",
    "react-resizable-panels": "^4.5.7",
    "recharts": "2.15.4",
    "resend": "^6.9.1",
    "server-only": "^0.0.1",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.12",
    "@react-email/preview-server": "5.2.8",
    "@tailwindcss/postcss": "^4",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@trigger.dev/build": "4.4.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "drizzle-kit": "^0.31.8",
    "lefthook": "^2.0.16",
    "react-email": "5.2.8",
